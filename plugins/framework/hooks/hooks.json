{
  "description": "Manages framework lifecycle across session events",
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/skills/framework-initialization/scripts/prompt\" -k message.cache_restoration",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/skills/framework-initialization/scripts/memory\" -s",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/skills/framework-initialization/scripts/memory\" -r",
            "timeout": 10
          }
        ],
        "matcher": "clear|compact"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/skills/framework-initialization/scripts/prompt\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
